      "computedValue": "{{(() => { const tableData = TableClinica.processedTableData || []; return tableData.length > 0 ? tableData.map((currentRow, currentIndex) => ( \n  (() => {\n    const num = currentRow.clinica001_telefone ? currentRow.clinica001_telefone.toString().replace(/\\D/g, \"\") : \"\";\n    \n    if (num.length === 11) {\n      // Celular: (00) 00000-0000\n      return num.replace(/^(\\d{2})(\\d{5})(\\d{4})$/, \"($1) $2-$3\");\n    } else if (num.length === 10) {\n      // Fixo: (00) 0000-0000\n      return num.replace(/^(\\d{2})(\\d{4})(\\d{4})$/, \"($1) $2-$3\");\n    }\n    \n    return num; \n  })() \n)) :  \n  (() => {\n    const num = currentRow.clinica001_telefone ? currentRow.clinica001_telefone.toString().replace(/\\D/g, \"\") : \"\";\n    \n    if (num.length === 11) {\n      // Celular: (00) 00000-0000\n      return num.replace(/^(\\d{2})(\\d{5})(\\d{4})$/, \"($1) $2-$3\");\n    } else if (num.length === 10) {\n      // Fixo: (00) 0000-0000\n      return num.replace(/^(\\d{2})(\\d{4})(\\d{4})$/, \"($1) $2-$3\");\n    }\n    \n    return num; \n  })() \n })()}}",
